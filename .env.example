API_PORT=3001
NODE_ENV=development
SERVE_STATIC=false

# Subdominio publico do frontend. Em producao, use HTTPS.
PUBLIC_ORIGIN=https://horarios.seudominio.edu.br

# Origens extras permitidas quando frontend e API estiverem em hosts diferentes.
# Exemplo: https://horarios.seudominio.edu.br,https://api-horarios.seudominio.edu.br
ALLOWED_ORIGINS=

# Use 1 quando a API estiver atras de proxy reverso/load balancer.
TRUST_PROXY=1
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha
DB_NAME=cimol
DB_CONNECTION_LIMIT=10

# Usuários iniciais do painel. Troque as senhas antes de usar em produção.
ADMIN_NAME=Administrador
ADMIN_USER=admin
ADMIN_PASSWORD=troque_esta_senha
CPD_NAME=CPD
CPD_USER=cpd
CPD_PASSWORD=troque_esta_senha

# Cookies de sessao. Para mesmo subdominio com proxy /api, deixe COOKIE_DOMAIN vazio.
# Para compartilhar entre subdominios, use algo como .seudominio.edu.br.
COOKIE_DOMAIN=
COOKIE_SAMESITE=Lax
COOKIE_SECURE=true

# Limites de requisicoes por IP.
API_RATE_LIMIT=600
API_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT=20
AUTH_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_RATE_LIMIT=30
UPLOAD_RATE_LIMIT_WINDOW_MS=900000

# Frontend em producao normalmente usa /api no mesmo subdominio.
# Preencha apenas se a API estiver em outro origin.
VITE_API_BASE_URL=
VITE_API_PROXY_TARGET=http://localhost:3001

# Servidor web de desenvolvimento.
WEB_HOST=0.0.0.0
WEB_PORT=8080
WEB_ALLOWED_HOSTS=localhost,127.0.0.1

# Opcional quando o executável não estiver disponível no PATH.
PYTHON_BIN=C:\Program Files\Python310\python.exe

# Compatibilidade temporária com consumidores antigos de /api/reorganizacao.
VITE_API_KEY=substitua_por_uma_chave_aleatoria_forte
