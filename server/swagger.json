{
  "openapi": "3.0.3",
  "info": {
    "title": "CIMOL - Gestão Escolar API",
    "version": "2.0.0",
    "description": "API de horários URÂNIA UP, blocos, salas e reorganização. Importações passam por uma área temporária e somente versões aprovadas pelo CPD são publicadas."
  },
  "servers": [{ "url": "http://localhost:3001", "description": "Desenvolvimento" }],
  "tags": [
    { "name": "Autenticação" },
    { "name": "URÂNIA UP" },
    { "name": "Horários públicos" },
    { "name": "Eventos" },
    { "name": "Setores" },
    { "name": "Ouvidoria" },
    { "name": "Blocos" },
    { "name": "Salas" },
    { "name": "Reorganização" }
  ],
  "components": {
    "securitySchemes": {
      "SessionCookie": { "type": "apiKey", "in": "cookie", "name": "cimol_session" },
      "LegacyApiKey": { "type": "apiKey", "in": "header", "name": "x-api-key" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "message": { "type": "string" } }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "nome": { "type": "string" },
          "usuario": { "type": "string" },
          "papel": { "type": "string", "enum": ["ADMIN", "CPD"] }
        }
      },
      "BlocoInput": {
        "type": "object",
        "required": ["nome"],
        "properties": { "nome": { "type": "string" }, "descricao": { "type": "string", "nullable": true } }
      },
      "SalaInput": {
        "type": "object",
        "required": ["bloco_id", "nome", "andar", "tipo"],
        "properties": {
          "bloco_id": { "type": "integer" },
          "nome": { "type": "string" },
          "andar": { "type": "string" },
          "capacidade": { "type": "integer", "minimum": 1, "nullable": true },
          "tipo": { "type": "string" },
          "possui_computadores": { "type": "boolean" },
          "possui_data_show": { "type": "boolean" },
          "possui_internet": { "type": "boolean" },
          "possui_ar_condicionado": { "type": "boolean" },
          "softwares": { "type": "array", "items": { "type": "string" } },
          "observacoes": { "type": "string", "nullable": true }
        }
      },
      "Horario": {
        "type": "object",
        "properties": {
          "turma": { "type": "string", "example": "INFO 63 1" },
          "curso": { "type": "string", "example": "Informática" },
          "ano": { "type": "string", "example": "3" },
          "dia": { "type": "string", "example": "SEG" },
          "periodo": { "type": "integer", "example": 1 },
          "hora_inicio": { "type": "string", "nullable": true, "example": "07:30" },
          "disciplina": { "type": "string" },
          "professor": { "type": "string", "nullable": true },
          "sala_id": { "type": "integer", "nullable": true },
          "ambiente": { "type": "string", "nullable": true },
          "sala": { "type": "string", "nullable": true }
        }
      },
      "EventoInput": {
        "type": "object",
        "required": ["titulo", "data_evento"],
        "properties": {
          "titulo": { "type": "string" },
          "descricao": { "type": "string", "nullable": true },
          "data_evento": { "type": "string", "format": "date" },
          "hora_evento": { "type": "string", "nullable": true, "example": "19:30" },
          "local": { "type": "string", "nullable": true },
          "imagem_url": { "type": "string", "nullable": true },
          "ativo": { "type": "boolean" }
        }
      },
      "SetorInput": {
        "type": "object",
        "required": ["nome", "descricao"],
        "properties": {
          "nome": { "type": "string" },
          "descricao": { "type": "string" },
          "responsavel": { "type": "string", "nullable": true },
          "localizacao": { "type": "string", "nullable": true },
          "contato": { "type": "string", "nullable": true },
          "horario_atendimento": { "type": "string", "nullable": true },
          "icone": { "type": "string" },
          "cor": { "type": "string" },
          "ativo": { "type": "boolean" }
        }
      },
      "OuvidoriaInput": {
        "type": "object",
        "required": ["perfil", "categoria", "assunto", "mensagem"],
        "properties": {
          "nome": { "type": "string", "nullable": true },
          "perfil": { "type": "string", "enum": ["ALUNO", "DOCENTE", "RESPONSAVEL", "COMUNIDADE"] },
          "categoria": { "type": "string", "enum": ["IDEIA", "MELHORIA", "PROBLEMA", "AVISO"] },
          "setor_id": { "type": "integer", "nullable": true },
          "assunto": { "type": "string" },
          "mensagem": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": { "summary": "Verificar API e banco", "responses": { "200": { "description": "Disponível" } } }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Autenticação"], "summary": "Iniciar sessão",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["usuario", "senha"], "properties": { "usuario": { "type": "string" }, "senha": { "type": "string", "format": "password" } } } } } },
        "responses": { "200": { "description": "Sessão criada" }, "401": { "description": "Credenciais inválidas" } }
      }
    },
    "/api/auth/me": {
      "get": { "tags": ["Autenticação"], "summary": "Consultar sessão", "security": [{ "SessionCookie": [] }], "responses": { "200": { "description": "Usuário autenticado" }, "401": { "description": "Sem sessão" } } }
    },
    "/api/auth/logout": {
      "post": { "tags": ["Autenticação"], "summary": "Encerrar sessão", "responses": { "200": { "description": "Sessão encerrada" } } }
    },
    "/api/importacoes/urania": {
      "post": {
        "tags": ["URÂNIA UP"], "summary": "Enviar HTML/XML para a área temporária", "description": "Somente o operador URÂNIA (papel ADMIN). Esse papel não acessa a análise ou outros módulos.", "security": [{ "SessionCookie": [] }],
        "requestBody": { "required": true, "content": { "multipart/form-data": { "schema": { "type": "object", "required": ["arquivos"], "properties": { "arquivos": { "type": "array", "items": { "type": "string", "format": "binary" } }, "observacoes": { "type": "string" } } } } } },
        "responses": { "201": { "description": "Importação pendente criada" }, "400": { "description": "Arquivo inválido" }, "403": { "description": "Papel não autorizado" }, "422": { "description": "Estrutura URÂNIA inválida" } }
      }
    },
    "/api/importacoes": {
      "get": { "tags": ["URÂNIA UP"], "summary": "Listar pendências e histórico", "description": "Somente CPD.", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "query", "name": "status", "schema": { "type": "string", "enum": ["PENDENTE", "APROVADA", "REJEITADA"] } }], "responses": { "200": { "description": "Importações" } } }
    },
    "/api/importacoes/{id}": {
      "get": { "tags": ["URÂNIA UP"], "summary": "Visualizar importação e horários", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }, { "in": "query", "name": "turma", "schema": { "type": "string" } }], "responses": { "200": { "description": "Prévia" }, "404": { "description": "Não encontrada" } } }
    },
    "/api/importacoes/{id}/aprovar": {
      "post": { "tags": ["URÂNIA UP"], "summary": "Aprovar e publicar", "description": "Somente CPD.", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Publicada" }, "403": { "description": "Papel não autorizado" }, "409": { "description": "Já revisada" } } }
    },
    "/api/importacoes/{id}/rejeitar": {
      "post": { "tags": ["URÂNIA UP"], "summary": "Rejeitar importação", "description": "Somente CPD.", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["motivo"], "properties": { "motivo": { "type": "string" } } } } } }, "responses": { "200": { "description": "Rejeitada" }, "400": { "description": "Motivo ausente" } } }
    },
    "/api/horarios/publicados": {
      "get": { "tags": ["Horários públicos"], "summary": "Consultar somente horários aprovados e ativos", "parameters": [{ "in": "query", "name": "turma", "schema": { "type": "string" } }, { "in": "query", "name": "curso", "schema": { "type": "string" } }, { "in": "query", "name": "ano", "schema": { "type": "string" } }, { "in": "query", "name": "dia", "schema": { "type": "string" } }, { "in": "query", "name": "apenas_opcoes", "schema": { "type": "boolean" } }], "responses": { "200": { "description": "Turmas e horários publicados" } } }
    },
    "/api/horarios/publicados/{id}/sala": {
      "patch": { "tags": ["Horários públicos"], "summary": "Configurar sala de um horário publicado", "description": "Somente CPD. Atualiza o vínculo de sala de uma aula publicada e ativa.", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "properties": { "sala_id": { "type": "integer", "nullable": true } } } } } }, "responses": { "200": { "description": "Sala configurada" }, "400": { "description": "Sala inválida" }, "401": { "description": "Sem sessão" }, "403": { "description": "Papel não autorizado" }, "404": { "description": "Horário não encontrado" } } }
    },
    "/api/eventos": {
      "get": { "tags": ["Eventos"], "summary": "Listar eventos publicados", "parameters": [{ "in": "query", "name": "incluir_inativos", "schema": { "type": "boolean" } }], "responses": { "200": { "description": "Eventos" } } },
      "post": { "tags": ["Eventos"], "summary": "Cadastrar evento", "security": [{ "SessionCookie": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventoInput" } } } }, "responses": { "201": { "description": "Criado" } } }
    },
    "/api/eventos/{id}": {
      "put": { "tags": ["Eventos"], "summary": "Atualizar evento", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/EventoInput" } } } }, "responses": { "200": { "description": "Atualizado" } } },
      "delete": { "tags": ["Eventos"], "summary": "Excluir evento", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Excluído" } } }
    },
    "/api/setores": {
      "get": { "tags": ["Setores"], "summary": "Listar setores publicados", "parameters": [{ "in": "query", "name": "incluir_inativos", "schema": { "type": "boolean" } }], "responses": { "200": { "description": "Setores" } } },
      "post": { "tags": ["Setores"], "summary": "Cadastrar setor", "security": [{ "SessionCookie": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetorInput" } } } }, "responses": { "201": { "description": "Criado" } } }
    },
    "/api/setores/{id}": {
      "put": { "tags": ["Setores"], "summary": "Atualizar setor", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SetorInput" } } } }, "responses": { "200": { "description": "Atualizado" } } },
      "delete": { "tags": ["Setores"], "summary": "Excluir setor", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Excluído" } } }
    },
    "/api/ouvidoria": {
      "post": { "tags": ["Ouvidoria"], "summary": "Enviar manifestação", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/OuvidoriaInput" } } } }, "responses": { "201": { "description": "Recebida" }, "400": { "description": "Texto inválido ou impróprio" } } },
      "get": { "tags": ["Ouvidoria"], "summary": "Listar manifestações", "description": "Somente CPD.", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "query", "name": "status", "schema": { "type": "string", "enum": ["NOVA", "EM_ANALISE", "RESOLVIDA", "ARQUIVADA"] } }], "responses": { "200": { "description": "Manifestações" } } }
    },
    "/api/ouvidoria/{id}": {
      "patch": { "tags": ["Ouvidoria"], "summary": "Atualizar status da manifestação", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "type": "object", "required": ["status"], "properties": { "status": { "type": "string", "enum": ["NOVA", "EM_ANALISE", "RESOLVIDA", "ARQUIVADA"] } } } } } }, "responses": { "200": { "description": "Status atualizado" } } }
    },
    "/api/blocos": {
      "get": { "tags": ["Blocos"], "summary": "Listar blocos", "responses": { "200": { "description": "Blocos" } } },
      "post": { "tags": ["Blocos"], "summary": "Cadastrar bloco", "security": [{ "SessionCookie": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BlocoInput" } } } }, "responses": { "201": { "description": "Criado" } } }
    },
    "/api/blocos/{id}": {
      "put": { "tags": ["Blocos"], "summary": "Atualizar bloco", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BlocoInput" } } } }, "responses": { "200": { "description": "Atualizado" } } },
      "delete": { "tags": ["Blocos"], "summary": "Excluir bloco sem salas", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Excluído" }, "409": { "description": "Possui salas" } } }
    },
    "/api/salas": {
      "get": { "tags": ["Salas"], "summary": "Consultar salas e recursos", "parameters": [{ "in": "query", "name": "bloco_id", "schema": { "type": "integer" } }, { "in": "query", "name": "capacidade_minima", "schema": { "type": "integer" } }, { "in": "query", "name": "tipo", "schema": { "type": "string" } }, { "in": "query", "name": "software", "schema": { "type": "string" } }], "responses": { "200": { "description": "Salas" } } },
      "post": { "tags": ["Salas"], "summary": "Cadastrar sala", "security": [{ "SessionCookie": [] }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SalaInput" } } } }, "responses": { "201": { "description": "Criada" } } }
    },
    "/api/salas/{id}": {
      "get": { "tags": ["Salas"], "summary": "Consultar sala", "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Sala" } } },
      "put": { "tags": ["Salas"], "summary": "Atualizar sala", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SalaInput" } } } }, "responses": { "200": { "description": "Atualizada" } } },
      "delete": { "tags": ["Salas"], "summary": "Excluir sala", "security": [{ "SessionCookie": [] }], "parameters": [{ "in": "path", "name": "id", "required": true, "schema": { "type": "integer" } }], "responses": { "200": { "description": "Excluída" } } }
    },
    "/api/reorganizacao": {
      "get": { "tags": ["Reorganização"], "summary": "Listar solicitações", "security": [{ "SessionCookie": [] }, { "LegacyApiKey": [] }], "responses": { "200": { "description": "Solicitações" } } },
      "post": { "tags": ["Reorganização"], "summary": "Criar solicitação", "security": [{ "SessionCookie": [] }, { "LegacyApiKey": [] }], "responses": { "201": { "description": "Criada" } } }
    }
  }
}
